<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_primary"
        app:navigationIcon="@drawable/ic_close"
        app:titleTextColor="@color/text_primary" />

    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_secondary"
        android:padding="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        tools:text="Connecting…" />

    <ScrollView
        android:id="@+id/output_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="8dp">

        <TextView
            android:id="@+id/output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/terminal_fg"
            android:textIsSelectable="true"
            android:textSize="13sp" />
    </ScrollView>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_secondary"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/key_esc"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:minWidth="44dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/terminal_key_esc"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/key_tab"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:minWidth="44dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/terminal_key_tab"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/key_up"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:minWidth="44dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/terminal_key_up"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/key_down"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:minWidth="44dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/terminal_key_down"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/key_left"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:minWidth="44dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/terminal_key_left"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/key_right"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:minWidth="44dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/terminal_key_right"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/key_ctrl_d"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:minWidth="44dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/terminal_key_ctrl_d"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/key_ctrl_l"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:minWidth="44dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/terminal_key_ctrl_l"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/key_ctrl_z"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:minWidth="44dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/terminal_key_ctrl_z"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/key_enter"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:minWidth="44dp"
                android:minHeight="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/terminal_key_enter"
                android:textColor="@color/text_primary" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_secondary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="6dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ctrl_c"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:paddingHorizontal="10dp"
            android:text="@string/terminal_action_ctrl_c"
            android:textColor="@color/text_primary" />

        <EditText
            android:id="@+id/input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@color/bg_elevated"
            android:fontFamily="monospace"
            android:hint="@string/terminal_send_hint"
            android:imeOptions="actionSend"
            android:inputType="text|textNoSuggestions"
            android:padding="10dp"
            android:textColor="@color/terminal_fg"
            android:textColorHint="@color/text_tertiary"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:backgroundTint="@color/brand_blue"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:text="@string/terminal_action_send"
            android:textColor="@color/text_primary" />
    </LinearLayout>
</LinearLayout>
