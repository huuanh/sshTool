<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".App"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TermiusClone"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.TermiusClone">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="ssh" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.hosteditor.HostEditorActivity"
            android:exported="false"
            android:label="@string/title_host_editor"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.identities.IdentityEditorActivity"
            android:exported="false"
            android:label="@string/title_identity_editor"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.terminal.TerminalActivity"
            android:exported="false"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize"
            android:windowSoftInputMode="adjustResize|stateVisible" />

        <activity
            android:name=".ui.sftp.SftpActivity"
            android:exported="false"
            android:label="@string/sftp_title"
            android:windowSoftInputMode="adjustResize" />

    </application>
</manifest>
